# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/kagaz_ai

# ─── Supabase Auth ────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-here

# ─── AI / LLM Service ─────────────────────────────────────────────────────────
LLAMA_API_BASE=https://api.groq.com/openai/v1
LLAMA_API_KEY=gsk_...
LLAMA_MODEL=llama3-8b-8192

# ─── OCR Pipeline ─────────────────────────────────────────────────────────────
# Use GPU for PaddleOCR (requires paddlepaddle-gpu installed)
OCR_USE_GPU=false

# Default recognition language (en, hi, ar, ch, fr, es, de, japan, korean)
OCR_LANG=en

# CLAHE clip limit for low-light enhancement (higher = more aggressive)
OCR_CLAHE_CLIP=3.0

# Shadow removal morphological kernel size (must be odd, larger = wider shadows)
OCR_SHADOW_KERNEL=91

# Deskew angle search limit in degrees (max rotation to correct)
OCR_DESKEW_LIMIT=45.0

# Minimum angle (degrees) below which deskew is skipped
OCR_DESKEW_THRESH=0.5

# Non-local means denoising strength (higher = more smoothing)
OCR_NLM_H=10

# Minimum OCR confidence threshold [0.0 – 1.0], blocks below this are dropped
OCR_MIN_CONF=0.4

# Fraction of image height treated as the header zone (student info)
OCR_HEADER_RATIO=0.22

# Save intermediate debug images to OCR_DEBUG_DIR
OCR_DEBUG=false
OCR_DEBUG_DIR=debug_ocr
